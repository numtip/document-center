# === RAE Migration Staging — binary files ===
# Block all document binary files. Only metadata/scripts/reports are tracked.
.migration/rae-wtms/files/
.migration/rae-wtms/review/
# Allow metadata, tools, reports (not binary)
!.migration/rae-wtms/metadata/
!.migration/rae-wtms/tools/
!.migration/rae-wtms/reports/
# Playwright M365 auth profiles — never commit cookies/tokens
.browser-profile/
.migration/rae-wtms/tools/temp_profile*/
# PXP-3 rollback and working data — never commit live auth metadata
.migration/pxp3/
