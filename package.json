{
  "name": "rae-document-center",
  "version": "1.0.3",
  "private": true,
  "description": "RAE Enterprise Canonical Repository — architecture, metadata standards, and M365 integration patterns",
  "scripts": {
    "validate:matrix": "tsx scripts/validate-document-migration-matrix.ts docs/document-center/migration-matrix.v2.csv",
    "validate:registry": "tsx scripts/validate-document-registry.ts docs/document-center/document-registry.draft.json docs/document-center/taxonomy.json",
    "generate:registry": "tsx scripts/generate-registry-draft.ts docs/document-center/migration-matrix.v2.csv docs/document-center/taxonomy.json docs/document-center/document-registry.draft.json",
    "generate:prep-map": "tsx scripts/generate-onedrive-prep-map.ts docs/document-center/document-registry.draft.json docs/document-center/taxonomy.json docs/document-center/onedrive-migration-prep.csv",
    "validate:all": "npm run validate:matrix && npm run validate:registry",
    "validate:pages": "tsx scripts/validate-pages.ts",
    "build": "tsx scripts/build-preview.ts",
    "lint": "npm run validate:pages"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
